        "    situacao = \"Aprovado\"\n",
        "else:\n",
        "    situacao = \"Reprovado\"\n",
        "\n",
        "# Saida\n",
        "\n",
        "# Imprime a situação do aluno\n",
        "print(f\"O aluno está: {situacao}\")"
